{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me-snowy-one.vercel.app/schemas/recipe-v1.json",
  "title": "Recipe v1.0",
  "type": "object",
  "required": [
    "schema",
    "title",
    "category",
    "for_whom",
    "time_min",
    "tested",
    "servings",
    "kbju",
    "sections"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "1.0" },

    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^(?!\\d+\\.\\d+\\s).*"
    },

    "icon": { "type": "string", "maxLength": 8 },

    "category": {
      "type": "string",
      "enum": [
        "🧒 Детские",
        "🍲 Супы",
        "🥘 Основные",
        "🌅 Завтраки",
        "🥄 Соусы и заправки",
        "🍎 Перекусы",
        "🍰 Выпечка и десерты"
      ]
    },

    "for_whom": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["Взрослые", "Дети 12+ мес.", "Вся семья"] }
    },

    "meal_types": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack", "dessert"] }
    },

    "main_ingredients": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "chicken", "beef", "pork", "fish", "seafood",
          "eggs", "dairy", "cheese",
          "pasta", "rice", "potatoes", "bread", "grains",
          "vegetables", "legumes", "fruits", "nuts_seeds"
        ]
      }
    },

    "allergens": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["milk", "eggs", "gluten", "nuts", "fish", "soy", "sesame", "peanuts"]
      }
    },

    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 40 }
    },

    "season": {
      "type": "string",
      "enum": ["spring", "summer", "autumn", "winter", "all"]
    },

    "time_min": { "type": "number", "minimum": 1, "maximum": 720 },
    "active_time_min": { "type": "number", "minimum": 1, "maximum": 720 },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "tested": { "type": "boolean" },

    "servings": {
      "type": "object",
      "required": ["adult", "kid"],
      "additionalProperties": false,
      "properties": {
        "adult": { "type": "integer", "minimum": 0, "maximum": 50 },
        "kid": { "type": "integer", "minimum": 0, "maximum": 50 }
      }
    },

    "yield_note": { "type": "string", "maxLength": 200 },

    "kbju": { "$ref": "#/$defs/kbju" },
    "kbju_kid": { "$ref": "#/$defs/kbju" },

    "sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/section" }
    },

    "params": { "$ref": "#/$defs/params" },

    "equipment": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },

    "alternatives": {
      "type": "array",
      "maxItems": 10,
      "items": { "$ref": "#/$defs/alternative" }
    },

    "substitutions": {
      "type": "array",
      "maxItems": 30,
      "items": { "$ref": "#/$defs/substitution" }
    },

    "prep_ahead": { "type": "string", "maxLength": 2000 },

    "serving": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temp_c": { "type": "number", "minimum": -20, "maximum": 100 },
        "pairs_with": { "type": "string", "maxLength": 500 },
        "size_note": { "type": "string", "maxLength": 500 }
      }
    },

    "mistakes": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["symptom", "cause", "fix"],
        "additionalProperties": false,
        "properties": {
          "symptom": { "type": "string", "minLength": 1, "maxLength": 200 },
          "cause": { "type": "string", "minLength": 1, "maxLength": 300 },
          "fix": { "type": "string", "minLength": 1, "maxLength": 400 }
        }
      }
    },

    "tips": {
      "type": "array",
      "maxItems": 15,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },

    "storage": {
      "type": "object",
      "required": ["fridge_days"],
      "additionalProperties": false,
      "properties": {
        "fridge_days": { "type": ["number", "null"], "minimum": 0, "maximum": 30 },
        "freezer_months": { "type": ["number", "null"], "minimum": 0, "maximum": 24 },
        "reheat": { "type": "string", "maxLength": 500 }
      }
    },

    "video_url": { "type": "string", "format": "uri", "pattern": "^https://" },

    "source_note": { "type": "string", "maxLength": 300 },

    "sources": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "type": { "type": "string", "enum": ["safety", "technique", "nutrition", "age"] }
        }
      }
    }
  },

  "$defs": {
    "kbju": {
      "type": "object",
      "required": ["kcal", "protein_g", "fat_g", "carbs_g", "portion_g"],
      "additionalProperties": false,
      "properties": {
        "kcal": { "type": "number", "minimum": 0, "maximum": 3000 },
        "protein_g": { "type": "number", "minimum": 0, "maximum": 300 },
        "fat_g": { "type": "number", "minimum": 0, "maximum": 300 },
        "carbs_g": { "type": "number", "minimum": 0, "maximum": 500 },
        "portion_g": { "type": "number", "minimum": 1, "maximum": 5000 }
      }
    },

    "ingredient": {
      "type": "object",
      "required": ["name", "amount_text"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "amount_g": { "type": "number", "minimum": 0, "maximum": 50000 },
        "amount_text": { "type": "string", "minLength": 1, "maxLength": 200 },
        "critical": { "type": "boolean" },
        "loss_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "step": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "timer_min": { "type": "number", "minimum": 0.1, "maximum": 1440 },
        "timer_type": { "type": "string", "enum": ["fixed", "adjustable"] },
        "timer_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number", "minimum": 0.1 }
        }
      },
      "dependentRequired": {
        "timer_min": ["timer_type"],
        "timer_range": ["timer_min"]
      },
      "allOf": [
        {
          "if": {
            "required": ["timer_range"],
            "properties": { "timer_type": { "const": "fixed" } }
          },
          "then": { "not": { "required": ["timer_range"] } }
        }
      ]
    },

    "section": {
      "type": "object",
      "required": ["type", "name"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["linear", "ingredient_group"] },
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "note": { "type": "string", "maxLength": 500 },
        "ingredients": { "type": "array", "items": { "$ref": "#/$defs/ingredient" } },
        "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "linear" } } },
          "then": { "required": ["ingredients", "steps"] }
        },
        {
          "if": { "properties": { "type": { "const": "ingredient_group" } } },
          "then": {
            "required": ["ingredients"],
            "not": { "required": ["steps"] },
            "properties": { "ingredients": { "minItems": 1 } }
          }
        }
      ]
    },

    "params": {
      "type": "object",
      "required": ["device", "time_text", "readiness"],
      "additionalProperties": false,
      "properties": {
        "device": { "type": "string", "minLength": 1, "maxLength": 100 },
        "mode": { "type": "string", "maxLength": 100 },
        "level": { "type": ["string", "null"], "maxLength": 50 },
        "temp_c": { "type": "number", "minimum": 0, "maximum": 350 },
        "time_text": { "type": "string", "minLength": 1, "maxLength": 200 },
        "internal_temp": {
          "type": "object",
          "required": ["value_c", "note"],
          "additionalProperties": false,
          "properties": {
            "value_c": { "type": "number", "minimum": 40, "maximum": 100 },
            "note": { "type": "string", "minLength": 20, "maxLength": 500 },
            "source": {
              "type": "string",
              "enum": [
                "usda_fsis_poultry",
                "usda_fsis_beef_whole",
                "usda_fsis_ground",
                "usda_fsis_fish",
                "usda_fsis_leftovers"
              ]
            }
          }
        },
        "readiness": { "type": "string", "minLength": 1, "maxLength": 300 },
        "output": { "type": "string", "maxLength": 200 }
      }
    },

    "alternative": {
      "type": "object",
      "required": ["device", "time_text"],
      "additionalProperties": false,
      "properties": {
        "device": { "type": "string", "minLength": 1, "maxLength": 100 },
        "mode": { "type": "string", "maxLength": 200 },
        "time_text": { "type": "string", "minLength": 1, "maxLength": 200 },
        "note": { "type": ["string", "null"], "maxLength": 300 }
      }
    },

    "substitution": {
      "type": "object",
      "required": ["original", "alternatives"],
      "additionalProperties": false,
      "properties": {
        "original": { "type": "string", "minLength": 1, "maxLength": 100 },
        "alternatives": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "note": { "type": "string", "maxLength": 300 }
      }
    }
  }
}
